{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-and-run",
      "type": "shell",
      "command": "make debug && WINEDEBUG=-all wine build/game.exe",
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build-release",
      "type": "shell",
      "command": "make release",
      "problemMatcher": ["$gcc"]
    }
  ]
}
