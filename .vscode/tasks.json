{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-debug",
      "type": "shell",
      "command": "echo BUILDING... && make debug",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "build-release",
      "type": "shell",
      "command": "echo BUILDING... && make release",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "build-and-run",
      "type": "shell",
      "command": "make debug && WINEDEBUG=-all wine build/game.exe",
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}