{
    "version": 4,
    "configurations": [
        {
            "name": "Win32 (MinGW cross-compile)",
            "includePath": [
                "${workspaceFolder}/src/core",
                "${workspaceFolder}/src/gameplay",
                "${workspaceFolder}/src/world",
                "${workspaceFolder}/src/ui",
                "${workspaceFolder}/src/data",
                "/usr/x86_64-w64-mingw32/include",
                "/usr/lib/gcc/x86_64-w64-mingw32/10-win32/include"
            ],
            "defines": [
                "_WIN32",
                "WIN32"
            ],
            "compilerPath": "/usr/bin/x86_64-w64-mingw32-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64"
        }
    ]
}
